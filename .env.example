# Copy to .env and fill in only what you use. Load it however you like, e.g.:
#   export $(grep -v '^#' .env | xargs)
# Secrets live ONLY in the environment — never in config.json.

# Required if provider = "openrouter"
OPENROUTER_API_KEY=

# Required if chatSurface = "slack" (bot token, scopes: chat:write, im:write, im:history)
SLACK_BOT_TOKEN=

# Tests only — point the Slack connector at a local fake server
# SLACK_API_BASE=http://localhost:3000
